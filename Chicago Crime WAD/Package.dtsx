    <DTS:Executable
      DTS:refId="Package\Update DIM_DATE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{6BB10F47-54BD-422B-B529-C54B9EEDC30E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update DIM_DATE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1C40F63D-F55E-4340-A3D7-7036DECDD68A}"
          SQLTask:SqlStatementSource="UPDATE DIM_DATE SET&#xA;    full_date = TRY_CONVERT(DATETIME,&#xA;        CAST(year AS VARCHAR) + '-' + &#xA;        RIGHT('0' + CAST(month AS VARCHAR), 2) + '-' + &#xA;        RIGHT('0' + CAST(day AS VARCHAR), 2) + ' ' + &#xA;        RIGHT('0' + CAST(hour AS VARCHAR), 2) + ':00:00');&#xA;&#xA;UPDATE DIM_DATE SET&#xA;    month_name = CASE month&#xA;        WHEN 1  THEN 'Styczeń'&#xA;        WHEN 2  THEN 'Luty'&#xA;        WHEN 3  THEN 'Marzec'&#xA;        WHEN 4  THEN 'Kwiecień'&#xA;        WHEN 5  THEN 'Maj'&#xA;        WHEN 6  THEN 'Czerwiec'&#xA;        WHEN 7  THEN 'Lipiec'&#xA;        WHEN 8  THEN 'Sierpień'&#xA;        WHEN 9  THEN 'Wrzesień'&#xA;        WHEN 10 THEN 'Październik'&#xA;        WHEN 11 THEN 'Listopad'&#xA;        WHEN 12 THEN 'Grudzień'&#xA;    END,&#xA;    day_of_week = DATENAME(WEEKDAY, full_date),&#xA;    quarter = DATEPART(QUARTER, full_date);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
