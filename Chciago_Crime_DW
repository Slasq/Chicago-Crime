-- Utwórz bazę danych

CREATE DATABASE ChicagoCrime_DW;
GO
USE ChicagoCrime_DW;
GO

-- Tabele wymiarów

CREATE TABLE DIM_DATE (
    date_id         INT PRIMARY KEY,
    full_date       DATETIME,
    year            INT,
    month           INT,
    month_name      VARCHAR(20),
    day             INT,
    hour            INT,
    day_of_week     VARCHAR(15),
    quarter         INT
);

CREATE TABLE DIM_LOCATION (
    location_id     INT IDENTITY(1,1) PRIMARY KEY,
    block           VARCHAR(100),
    district        INT,
    ward            INT,
    community_area  INT,
    latitude        FLOAT,
    longitude       FLOAT,
    location_desc   VARCHAR(100)
);

CREATE TABLE DIM_CRIME_TYPE (
    crime_type_id   INT IDENTITY(1,1) PRIMARY KEY,
    iucr            VARCHAR(10),
    primary_type    VARCHAR(100),
    description     VARCHAR(200),
    fbi_code        VARCHAR(10)
);

CREATE TABLE DIM_ARREST (
    arrest_id       INT PRIMARY KEY,
    arrest          BIT,
    domestic        BIT,
    arrest_label    VARCHAR(10),
    domestic_label  VARCHAR(10)
);


-- Tabela faktów

CREATE TABLE FACT_CRIMES (
    crime_id        INT PRIMARY KEY,
    case_number     VARCHAR(20),
    date_id         INT FOREIGN KEY REFERENCES DIM_DATE(date_id),
    location_id     INT FOREIGN KEY REFERENCES DIM_LOCATION(location_id),
    crime_type_id   INT FOREIGN KEY REFERENCES DIM_CRIME_TYPE(crime_type_id),
    arrest_id       INT FOREIGN KEY REFERENCES DIM_ARREST(arrest_id),
    beat            INT,
    ward            INT,
    x_coordinate    FLOAT,
    y_coordinate    FLOAT
);
